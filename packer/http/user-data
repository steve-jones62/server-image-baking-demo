#cloud-config
autoinstall:
  version: 1
  identity:
    hostname: ubuntu-baked-demo
    username: packer
    password: "$6$rounds=4096$QruPoDxm8zCJwpgL$zlgZRSPxZlrF5Izk9Ko3htVQUOv1Xc4ec4f.sEQ7jfiVyYo9bRxXIpw5ZPKvXCwV0dgUu1Edi8rmxVIKshaEB."
  ssh:
    install-server: true
    allow-pw: true
  late-commands:
    - curtin in-target --target=/target -- mkdir -p /root/.ssh
    - curtin in-target --target=/target -- /bin/bash -c 'cat > /root/.ssh/authorized_keys <<'"'"'EOF'"'"'
      ssh-rsa  steve@SRJ-WIN11
      EOF'
    - curtin in-target --target=/target -- chmod 700 /root/.ssh
    - curtin in-target --target=/target -- chmod 600 /root/.ssh/authorized_keys
    - curtin in-target --target=/target -- /bin/bash -c "printf 'PermitRootLogin yes\nPubkeyAuthentication yes\nPasswordAuthentication yes\n' > /etc/ssh/sshd_config.d/99-root.conf"
  locale: en_US.UTF-8
  keyboard:
    layout: us
  storage:
    layout:
      name: direct
